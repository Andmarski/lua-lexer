{
    "name": "lua-lexer",
    "version": "1.1.2",
    "description": "A fast Lua lexer written in TypeScript",
    "main": "./build/index.js",
    "module": "./build/index.mjs",
    "types": "./build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "import": "./build/index.mjs",
            "require": "./build/index.js"
        }
    },
    "files": [
        "build"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Andmarski/lua-lexer.git"
    },
    "bugs": {
        "url": "https://github.com/Andmarski/lua-lexer/issues"
    },
    "homepage": "https://github.com/Andmarski/lua-lexer#readme",
    "scripts": {
        "dev": "tsx source/index.ts",
        "build": "tsup",
        "prepare": "npm run build",
        "bench": "tsx benchmarks/index.ts",
        "format": "prettier . --write"
    },
    "keywords": [
        "lua",
        "lexer",
        "tokenizer",
        "parser",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "type": "commonjs",
    "devDependencies": {
        "@types/luaparse": "^0.2.13",
        "@types/node": "^25.9.5",
        "luaparse": "^0.3.1",
        "mitata": "^1.0.34",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
