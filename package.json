{
    "name": "lua-lexer",
    "version": "0.1.0",
    "description": "A fast Lua lexer written in TypeScript",
    "main": "./build/index.js",
    "module": "./build/index.mjs",
    "types": "./build/index.d.ts",
    "exports": {
        ".": {
            "types": "./build/index.d.ts",
            "import": "./build/index.mjs",
            "require": "./build/index.js"
        }
    },
    "files": [
        "build"
    ],
    "scripts": {
        "dev": "tsx source/index.ts",
        "build": "tsup",
        "prepare": "npm run build",
        "bench:conditions": "tsx source/bench-conditions.ts",
        "bench:conditions:gc": "node --expose-gc ./node_modules/tsx/dist/cli.mjs source/bench-conditions.ts",
        "format": "prettier . --write"
    },
    "keywords": [
        "lua",
        "lexer",
        "tokenizer",
        "parser",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "type": "commonjs",
    "devDependencies": {
        "@types/node": "^25.5.2",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    }
}
